# ── .env.secret.example ────────────────────────────────────────────────────────
#
# Este arquivo é um MODELO. Nunca coloque valores reais aqui.
# No servidor, copie este arquivo como .env.secret e preencha os valores:
#
#   cp .env.secret.example .env.secret
#   chmod 600 .env.secret
#   nano .env.secret
#
# O .env.secret real está no .gitignore e nunca vai para o GitHub.

# Chave secreta do Flask — gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria

# Email para envio de recuperação de senha (Gmail)
EMAIL_REMETENTE=seu@gmail.com

# Senha de app do Google (não é a senha do Gmail)
# Gere em: myaccount.google.com > Segurança > Senhas de app
EMAIL_SENHA_APP=xxxx xxxx xxxx xxxx
